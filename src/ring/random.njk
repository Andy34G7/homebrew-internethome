<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homebrew Webring - Random Site</title>
</head>
<body>
    <script>
        // Extract actual site list
        const ringData = {{ sites.ring | dump | safe }};
        const sites = ringData[0].sites;

        // Get current site from query parameter
        const currentUrl = decodeURIComponent(
            new URLSearchParams(window.location.search).get('site') || ''
        );

        function getRandomSite() {
            // If only one site exists
            if (sites.length === 1) {
                return sites[0];
            }

            let randomIndex;

            do {
                randomIndex = Math.floor(
                    Math.random() * sites.length
                );
            } while (
                sites[randomIndex].url === currentUrl
            );

            return sites[randomIndex];
        }

        const targetSite = getRandomSite();

        if (targetSite && targetSite.url) {
            window.location.href = targetSite.url;
        } else {
            console.error('Invalid target site:', targetSite);

            document.body.innerHTML += `
                <p>Could not determine random site.</p>
            `;
        }
    </script>

    <p><a href="/">Back to Homebrew</a></p>
</body>
</html>