<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homebrew Webring - Previous Site</title>
</head>
<body>
    <script>
        const sites = {{ sites.ring | dump | safe }};
        const currentUrl = new URLSearchParams(window.location.search).get('site') || '';
        
        function getPrevSite() {
            const currentIndex = sites.findIndex(s => s.url === currentUrl);
            if (currentIndex === -1) {
                return sites[sites.length - 1];
            }
            return sites[(currentIndex - 1 + sites.length) % sites.length];
        }
        
        const targetSite = getPrevSite();
        if (targetSite) {
            window.location.href = targetSite.url;
        }
    </script>
    <p><a href="/">Back to Homebrew</a></p>
</body>
</html>
